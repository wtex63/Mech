<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE designrules SYSTEM "eagle.dtd">
<eagle version="9.7.0">
<designrules name="A350-CNC SMD-Aggressive 0603-0805 Rev3.1">
<classes>
<class number="0" name="default" clearance="6mil" drill="12mil">
</class>
<class number="1" name="SMD_Signal" clearance="4mil" drill="12mil">
</class>
<class number="2" name="Power" clearance="6mil" drill="12mil">
</class>
</classes>
<rules>
<rulecategory type="Copper Clearance" manualdrc="yes" livedrc="yes"/>
<rulecategory type="Keepout Clearance" manualdrc="yes" livedrc="yes"/>
<rulecategory type="Solder-Mask Clearance" manualdrc="yes" livedrc="yes"/>
<rulecategory type="Dimension Clearance" manualdrc="yes" livedrc="yes"/>
<rulecategory type="Drill Distance" manualdrc="yes" livedrc="yes"/>
<rulecategory type="Restrict Clearance" manualdrc="yes" livedrc="yes"/>
<rulecategory type="Minimum Drill Size" manualdrc="yes" livedrc="yes"/>
<rulecategory type="Minimum Copper Width" manualdrc="yes" livedrc="yes"/>
<rulecategory type="Acute Angle" manualdrc="yes" livedrc="yes"/>
<rulecategory type="Air-Wire" manualdrc="yes" livedrc="yes"/>
<rulecategory type="Small Gap" manualdrc="yes" livedrc="yes"/>
<rulecategory type="Wire Stub" manualdrc="yes" livedrc="no"/>
<rulecategory type="Matched Lengths" manualdrc="yes" livedrc="yes"/>
<rulecategory type="Via Restrict Clearance" manualdrc="yes" livedrc="yes"/>
<rule type="Minimum Copper Width" builtin_ruleid="14" enabled="yes" priority="0" value="5mil" preferredvalue="8mil" check_polywidth="no" name="minimum-copper-width-1"/>
<rule type="Minimum Drill Size" builtin_ruleid="15" enabled="yes" priority="0" value="12mil" preferredvalue="16mil" name="minimum-drill-size-1"/>
<rule type="Acute Angle" builtin_ruleid="16" enabled="no" priority="0" name="acute-angle-1"/>
<rule type="Wire Stub" builtin_ruleid="17" enabled="yes" priority="0" name="wire-stub-1"/>
<rule type="Air-Wire" builtin_ruleid="19" enabled="yes" priority="0" name="air-wire-1"/>
<rule type="Matched Lengths" builtin_ruleid="20" enabled="yes" priority="0" tolerance="10mm" gapfactor="2.5" name="matched-lengths-1"/>
<rule type="Copper Clearance" builtin_ruleid="0" enabled="yes" priority="0" onescope="is_wire_polygon" otherscope="is_wire_polygon" value="6mil" preferredvalue="8mil" samesignal="no" name="copper-clearance-wire-wire"/>
<rule type="Copper Clearance" builtin_ruleid="1" enabled="yes" priority="1" onescope="is_wire_polygon" otherscope="is_pad_smd" value="5mil" preferredvalue="8mil" samesignal="no" name="copper-clearance-wire-smpad"/>
<rule type="Copper Clearance" builtin_ruleid="2" enabled="yes" priority="2" onescope="is_wire_polygon" otherscope="is_via" value="5mil" preferredvalue="8mil" samesignal="no" name="copper-clearance-wire-via"/>
<rule type="Copper Clearance" builtin_ruleid="3" enabled="yes" priority="3" onescope="is_pad_smd" otherscope="is_pad_smd" value="6mil" preferredvalue="8mil" samesignal="no" name="copper-clearance-pad-pad"/>
<rule type="Copper Clearance" builtin_ruleid="4" enabled="yes" priority="4" onescope="is_pad_smd" otherscope="is_via" value="5mil" preferredvalue="8mil" samesignal="no" name="copper-clearance-pad-via"/>
<rule type="Copper Clearance" builtin_ruleid="5" enabled="yes" priority="5" onescope="is_via" otherscope="is_via" value="6mil" preferredvalue="8mil" samesignal="no" name="copper-clearance-via-via"/>
<rule type="Copper Clearance" builtin_ruleid="6" enabled="yes" priority="6" onescope="is_smd" otherscope="is_pad" value="4mil" preferredvalue="6mil" samesignal="yes" name="copper-clearance-smd-pad"/>
<rule type="Copper Clearance" builtin_ruleid="7" enabled="yes" priority="7" onescope="is_smd" otherscope="is_via" value="5mil" preferredvalue="6mil" samesignal="yes" name="copper-clearance-smd-via"/>
<rule type="Copper Clearance" builtin_ruleid="8" enabled="yes" priority="8" onescope="is_smd" otherscope="is_smd" value="4mil" preferredvalue="6mil" samesignal="yes" name="copper-clearance-smd-smd"/>
<rule type="Dimension Clearance" builtin_ruleid="9" enabled="yes" priority="0" value="15mil" preferredvalue="20mil" name="dimension-clearance-1"/>
<rule type="Via Restrict Clearance" builtin_ruleid="21" enabled="yes" priority="0" value="0mil" preferredvalue="0mil" name="via-restrict-clearance-1"/>
<rule type="Restrict Clearance" builtin_ruleid="10" enabled="yes" priority="0" value="0mil" preferredvalue="0mil" name="restrict-clearance-1"/>
<rule type="Small Gap" builtin_ruleid="18" enabled="yes" priority="0" name="small-gap-1"/>
<rule type="Solder-Mask Clearance" builtin_ruleid="11" enabled="no" priority="0" value="4mil" preferredvalue="4mil" check_name="yes" check_value="no" name="solder-mask-clearance-1"/>
<rule type="Drill Distance" builtin_ruleid="12" enabled="yes" priority="0" value="12mil" preferredvalue="16mil" name="drill-distance-1"/>
<rule type="Keepout Clearance" builtin_ruleid="13" enabled="yes" priority="0" value="0mil" preferredvalue="0mil" name="keepout-clearance-1"/>
</rules>
<param name="mdWireWire" value="6mil"/>
<param name="mdWirePad" value="5mil"/>
<param name="mdWireVia" value="5mil"/>
<param name="mdPadPad" value="6mil"/>
<param name="mdPadVia" value="5mil"/>
<param name="mdViaVia" value="6mil"/>
<param name="mdSmdPad" value="4mil"/>
<param name="mdSmdVia" value="5mil"/>
<param name="mdSmdSmd" value="4mil"/>
<param name="mdCopperDimension" value="15mil"/>
<param name="mdDrill" value="12mil"/>
<param name="mdViaViaSameLayer" value="6mil"/>
<param name="mdSmdStop" value="0mil"/>
<param name="msWidth" value="5mil"/>
<param name="msDrill" value="12mil"/>
<param name="msMicroVia" value="9.99mm"/>
<param name="msBlindViaRatio" value="0.5"/>
<param name="mnLayersViaInSmd" value="2"/>
<param name="dpMaxLengthDifference" value="10mm"/>
<param name="dpGapFactor" value="2.5"/>
<param name="rvPadTop" value="0.375"/>
<param name="rvPadInner" value="0.375"/>
<param name="rvPadBottom" value="0.375"/>
<param name="rvViaOuter" value="0.375"/>
<param name="rvViaInner" value="0.375"/>
<param name="rvMicroViaOuter" value="0.25"/>
<param name="rvMicroViaInner" value="0.25"/>
<param name="rlMinPadTop" value="6mil"/>
<param name="rlMaxPadTop" value="12mil"/>
<param name="rlMinPadInner" value="6mil"/>
<param name="rlMaxPadInner" value="12mil"/>
<param name="rlMinPadBottom" value="6mil"/>
<param name="rlMaxPadBottom" value="12mil"/>
<param name="rlMinViaOuter" value="6mil"/>
<param name="rlMaxViaOuter" value="12mil"/>
<param name="rlMinViaInner" value="6mil"/>
<param name="rlMaxViaInner" value="12mil"/>
<param name="rlMinMicroViaOuter" value="4mil"/>
<param name="rlMaxMicroViaOuter" value="12mil"/>
<param name="rlMinMicroViaInner" value="4mil"/>
<param name="rlMaxMicroViaInner" value="12mil"/>
<param name="psTop" value="-1"/>
<param name="psBottom" value="-1"/>
<param name="psFirst" value="-1"/>
<param name="psElongationLong" value="100"/>
<param name="psElongationOffset" value="100"/>
<param name="mvStopFrame" value="1"/>
<param name="mvCreamFrame" value="0"/>
<param name="mlMinStopFrame" value="4mil"/>
<param name="mlMaxStopFrame" value="4mil"/>
<param name="mlMinCreamFrame" value="0mil"/>
<param name="mlMaxCreamFrame" value="0mil"/>
<param name="mlViaStopLimit" value="0mil"/>
<param name="srRoundness" value="0"/>
<param name="srMinRoundness" value="0mil"/>
<param name="srMaxRoundness" value="0mil"/>
<param name="slThermalIsolate" value="14mil"/>
<param name="slThermalsForVias" value="0"/>
<param name="checkAngle" value="0"/>
<param name="checkRestrict" value="1"/>
<param name="checkStop" value="0"/>
<param name="checkValues" value="0"/>
<param name="checkNames" value="1"/>
<param name="checkWireStubs" value="1"/>
<param name="checkPolygonWidth" value="0"/>
<param name="useDiameter" value="13"/>
<param name="removeAnnularRing" value="0"/>
<param name="maxErrors" value="50"/>
<param name="layerSetup" value="(1*16)"/>
<param name="mtCopper" value="0.0175mm 0.0175mm 0.0175mm 0.0175mm 0.0175mm 0.0175mm 0.0175mm 0.0175mm 0.0175mm 0.0175mm 0.0175mm 0.0175mm 0.0175mm 0.0175mm 0.0175mm 0.0175mm"/>
<param name="mtIsolate" value="0.813mm 0.15mm 0.2mm 0.15mm 0.2mm 0.15mm 0.2mm 0.15mm 0.2mm 0.15mm 0.2mm 0.15mm 0.2mm 0.15mm 0.2mm"/>
<description language="en">Snapmaker A350 CNC SMD-Aggressive 0603-0805 Rev 3.1
Board: FR-4/G10 0.032in (0.813mm) | Copper: 0.5oz | A350 +/-0.05mm | Luban
Target: 0603 pad gap 28mil and 0805 pad gap 32mil
Wire-Wire: 6mil | Wire-SMD: 5mil | SMD-SMD: 4mil | SMD-Via: 5mil | Min Trace: 5mil
Net Classes: default=6mil | SMD_Signal=4mil | Power=6mil
Assign SMD_Signal class to all 0603/0805 signal nets in schematic</description>
<layerstackup name="A350 SMD-Aggressive 0.5oz FR4" type="Standard Stackup" display_unit="mic" roughness_model="0">
<layerdef type="Signal" id="{d4e5f6a7-b8c9-0123-defa-234567890123}" layer="1" name="Top" locally_modified_material="yes">
<material name="User Defined" thickness="0.0175mm" weight="0.5oz" process="Electro Deposited" source="User"/>
</layerdef>
<layerdef type="Core" id="{e5f6a7b8-c9d0-1234-efab-345678901234}" layer="1" name="Dielectric-1" locally_modified_material="yes">
<material name="FR-4" construction="" thickness="0.813mm" resin="50%" dielectric_constant_1g="4.5" dissipation_factor_1g="0.02" glass_transition_temperature="125degC" source="User"/>
</layerdef>
<layerdef type="Signal" id="{f6a7b8c9-d0e1-2345-fabc-456789012345}" layer="16" name="Bottom" locally_modified_material="yes">
<material name="User Defined" thickness="0.0175mm" weight="0.5oz" process="Electro Deposited" source="User"/>
</layerdef>
<viadef name="Thru 1:16" startlayer="1" stoplayer="16" complement="no"/>
</layerstackup>
</designrules>
</eagle>
